# Database
DATABASE_URL=postgresql://pda:pda@localhost:5432/pda

# Django
DEBUG=True
SECRET_KEY=
# Comma-separated hostnames. Required in production (the app refuses to boot if empty).
ALLOWED_HOSTS=
# Comma-separated origins (e.g. https://app.example.com). Required in production.
CORS_ALLOWED_ORIGINS=

# Cache / rate limiting (optional — leave empty for LocMemCache in dev).
# Set to a shared Redis instance in production so rate limits hold across
# workers. If empty in production, a database-backed cache is used instead
# (run `python manage.py createcachetable`).
REDIS_URL=

# Vetting
VETTING_EMAIL=

# Email (optional — leave empty for console backend in dev)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Resend (transactional email). Leave blank in dev to use console fallback.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Frontend base URL used in transactional emails (e.g. magic-login links).
# In production, set to the public app URL. Defaults to http://localhost:3000.
FRONTEND_BASE_URL=

# GitHub App feedback (optional — leave empty to disable feedback button)
# Credentials are in 1Password: "PDAFeedbackForm" (Shared vault)
#
# Populate with 1Password CLI:
#   GITHUB_APP_ID=$(op item get PDAFeedbackForm --fields "App ID")
#   GITHUB_APP_INSTALLATION_ID=$(op item get PDAFeedbackForm --fields "PDA Installation ID")
#   GITHUB_APP_PRIVATE_KEY=$(op read "op://Shared/PDAFeedbackForm/add more/pdafeedbackform.2026-03-31.private-key.pem" | base64 | tr -d '\n')
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_REPO=ProteinDeficientsAnonymous/pda

# Backblaze B2 media storage (optional — leave empty for local filesystem in dev)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT_URL=
B2_REGION=
